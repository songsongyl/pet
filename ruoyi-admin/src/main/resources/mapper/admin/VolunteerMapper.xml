<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.admin.mapper.VolunteerMapper">

    <resultMap type="com.ruoyi.admin.domain.Volunteer" id="VolunteerResult">
        <result property="volunteerId"    column="volunteer_id"    />
        <result property="name"    column="name"    />
        <result property="phone"    column="phone"    />
        <result property="email"    column="email"    />
        <result property="skills"    column="skills"    />
        <result property="status"    column="status"    />
        <result property="auditTime"    column="audit_time"    />
        <result property="auditUserId"    column="audit_user_id"    />
        <result property="auditComments"    column="audit_comments"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectVolunteerVo">
        select volunteer_id, name, phone, email, skills, status, audit_time, audit_user_id, audit_comments, create_time, update_time from volunteer
    </sql>

    <select id="selectVolunteerList" parameterType="com.ruoyi.admin.domain.Volunteer" resultMap="VolunteerResult">
        <include refid="selectVolunteerVo"/>
        <where>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="phone != null  and phone != ''"> and phone like concat('%', #{phone}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                and date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                and date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
    </select>

    <select id="selectVolunteerByVolunteerId" parameterType="Long" resultMap="VolunteerResult">
        <include refid="selectVolunteerVo"/>
        where volunteer_id = #{volunteerId}
    </select>

    <select id="selectVolunteerStats" resultType="com.ruoyi.admin.domain.Volunteer">
        select
            count(case when status = 0 then 1 end) as pendingCount,
            count(case when status = 1 then 1 end) as approvedCount,
            count(case when status = 2 then 1 end) as rejectedCount,
            count(case when status = 3 then 1 end) as cancelledCount,
            count(*) as totalCount
        from volunteer
    </select>

    <insert id="insertVolunteer" parameterType="com.ruoyi.admin.domain.Volunteer" useGeneratedKeys="true" keyProperty="volunteerId">
        insert into volunteer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="phone != null">phone,</if>
            <if test="email != null">email,</if>
            <if test="skills != null">skills,</if>
            <if test="status != null">status,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="auditUserId != null">audit_user_id,</if>
            <if test="auditComments != null">audit_comments,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="phone != null">#{phone},</if>
            <if test="email != null">#{email},</if>
            <if test="skills != null">#{skills},</if>
            <if test="status != null">#{status},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="auditUserId != null">#{auditUserId},</if>
            <if test="auditComments != null">#{auditComments},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateVolunteer" parameterType="com.ruoyi.admin.domain.Volunteer">
        update volunteer
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="skills != null">skills = #{skills},</if>
            <if test="status != null">status = #{status},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditUserId != null">audit_user_id = #{auditUserId},</if>
            <if test="auditComments != null">audit_comments = #{auditComments},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where volunteer_id = #{volunteerId}
    </update>

    <delete id="deleteVolunteerByVolunteerId" parameterType="Long">
        delete from volunteer where volunteer_id = #{volunteerId}
    </delete>

    <delete id="deleteVolunteerByVolunteerIds" parameterType="Long">
        delete from volunteer where volunteer_id in
        <foreach item="volunteerId" collection="array" open="(" separator="," close=")">
            #{volunteerId}
        </foreach>
    </delete>
</mapper>
